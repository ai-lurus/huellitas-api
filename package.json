{
  "name": "huellitas-api",
  "version": "0.1.0",
  "description": "Huellitas backend API — Node.js + Express + PostgreSQL",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "test": "jest --runInBand --forceExit",
    "test:watch": "jest --watch",
    "test:ci": "jest --ci --coverage --runInBand --forceExit",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write 'src/**/*.ts'",
    "prepare": "husky",
    "migrate": "ts-node src/db/migrate.ts",
    "create:test-user": "ts-node src/scripts/create-test-user.ts",
    "db:reset": "ts-node src/scripts/db-reset.ts",
    "auth:diagnose": "ts-node src/scripts/diagnose-auth-seed.ts"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.0.0",
    "@neondatabase/serverless": "^0.10.0",
    "@sentry/node": "^8.0.0",
    "better-auth": "^1.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.0.0",
    "expo-server-sdk": "^6.1.0",
    "express": "^4.18.0",
    "express-rate-limit": "^7.0.0",
    "firebase-admin": "^13.0.0",
    "helmet": "^7.0.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.0",
    "pg": "^8.11.0",
    "uuid": "^9.0.0",
    "winston": "^3.11.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^18.0.0",
    "@commitlint/config-conventional": "^18.0.0",
    "@types/cors": "^2.8.0",
    "@types/express": "^4.17.0",
    "@types/jest": "^29.0.0",
    "@types/multer": "^1.4.0",
    "@types/node": "^20.0.0",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.10.0",
    "@types/supertest": "^6.0.0",
    "@types/uuid": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.0.0",
    "husky": "^9.0.0",
    "jest": "^29.0.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.0.0",
    "supertest": "^6.3.0",
    "ts-jest": "^29.0.0",
    "ts-node": "^10.9.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.0"
  }
}
